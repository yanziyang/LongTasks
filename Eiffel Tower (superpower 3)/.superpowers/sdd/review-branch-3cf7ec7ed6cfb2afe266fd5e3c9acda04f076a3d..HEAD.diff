+  element.style.cssText =
+    'position:absolute;bottom:12px;left:12px;padding:10px 12px;' +
+    'background:rgba(10,10,18,0.7);color:#e8e8e8;font:13px/1.5 monospace;' +
+    'border-radius:6px;max-width:280px;z-index:10;';
